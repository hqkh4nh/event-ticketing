# App
NODE_ENV=development
PORT=3000
FRONTEND_URL=*

# Database (matches docker-compose postgres service)
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/event_ticketing?schema=public

# Auth
JWT_SECRET=replace-with-a-long-random-secret-min-16-chars
JWT_EXPIRES_IN=1d

# Ticket QR signing (HMAC-SHA256)
TICKET_HMAC_SECRET=replace-with-a-long-random-hmac-secret

# Orders
ORDER_HOLD_MINUTES=15

# SePay webhook (leave empty in dev)
SEPAY_WEBHOOK_API_KEY=

# Mail (SMTP; leave empty to disable email in dev)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
MAIL_FROM=Event Ticketing <no-reply@example.com>
